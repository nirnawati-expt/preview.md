{
  "manifest_version": 3,
  "name": "preview.md - Free Markdown Viewer",
  "description": "Open, read, done. Offline markdown viewer for your browser.",
  "version": "1.0",
  "permissions": ["tabs", "storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["viewer.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
